---
import { slugify } from '../utils/slugify';
const { post } = Astro.props;
const date = post.data.pubDate.toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' });
---
<article class="post-card">
  <h2><a href={`/posts/${post.slug}/`}>{post.data.title}</a></h2>
  <div class="post-meta">
    <time datetime={post.data.pubDate.toISOString()}>{date}</time>
    {post.data.tags.length > 0 && (
      <>
        <span> · </span>
        {post.data.tags.slice(0, 3).map((tag: string) => (
          <a class="tag-badge" href={`/tags/${slugify(tag)}/`} rel="tag">{tag}</a>
        ))}
      </>
    )}
  </div>
  {post.data.description && <p class="post-excerpt">{post.data.description}</p>}
</article>
