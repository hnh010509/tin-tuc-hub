---
const { title = 'tin-tuc-hub', description = 'Curated reference resources' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS Feed" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="article" />
  <style>
    body { font-family: system-ui, -apple-system, sans-serif; max-width: 720px; margin: 2rem auto; padding: 0 1rem; line-height: 1.6; color: #222; }
    nav { padding-bottom: 1rem; border-bottom: 1px solid #eee; margin-bottom: 2rem; }
    nav a { margin-right: 1rem; color: #0066cc; text-decoration: none; }
    h1, h2 { color: #1a1a1a; }
    a { color: #0066cc; }
    article { margin: 2rem 0; }
    .meta { color: #888; font-size: 0.9rem; }
    ul.posts { list-style: none; padding: 0; }
    ul.posts li { margin: 0.8rem 0; padding-bottom: 0.8rem; border-bottom: 1px solid #f0f0f0; }
  </style>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/rss.xml">RSS</a>
    <a href="/sitemap-index.xml">Sitemap</a>
  </nav>
  <main><slot /></main>
  <footer style="margin-top:3rem;padding-top:1rem;border-top:1px solid #eee;color:#888;font-size:0.85rem">
    <p>tin-tuc-hub © 2026</p>
  </footer>
</body>
</html>
