---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../utils/slugify';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const date = post.data.pubDate.toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' });

const wordCount = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const related = allPosts
  .filter(p => p.slug !== post.slug && p.data.tags.some((t: string) => post.data.tags.includes(t)))
  .slice(0, 3);

const breadcrumbs = [
  { name: 'Trang chủ', href: '/' },
  ...(post.data.tags[0] ? [{ name: post.data.tags[0], href: `/tags/${slugify(post.data.tags[0])}/` }] : []),
  { name: post.data.title, href: `/posts/${post.slug}/` }
];
---
<BaseLayout
  title={`${post.data.title} — Tin Tức Hub`}
  description={post.data.description || post.data.title}
  ogType="article"
  publishedTime={post.data.pubDate.toISOString()}
  author={post.data.author}
  breadcrumbs={breadcrumbs}
>
  <article>
    <header style="margin-bottom: 2rem">
      <h1>{post.data.title}</h1>
      <div class="post-meta" style="margin-top:0.5rem">
        <time datetime={post.data.pubDate.toISOString()}>{date}</time>
        <span> · </span>
        <span>Tác giả: <strong>{post.data.author}</strong></span>
        <span> · </span>
        <span>⏱ {readingTime} phút đọc</span>
        {post.data.tags.length > 0 && (
          <div style="margin-top:0.75rem">
            {post.data.tags.map((tag: string) => (
              <a class="tag-badge" href={`/tags/${slugify(tag)}/`} rel="tag">{tag}</a>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="post-content">
      <Content />
    </div>

    {post.data.sourceUrl && (
      <aside style="margin-top:2rem;padding:1rem;background:#f3f4f6;border-radius:8px;border-left:4px solid #2563eb">
        <strong>📎 Nguồn tham khảo:</strong><br/>
        <a href={post.data.sourceUrl} rel="noopener nofollow external">{post.data.sourceUrl}</a>
      </aside>
    )}
  </article>

  {related.length > 0 && (
    <section style="margin-top:3rem;padding-top:2rem;border-top:1px solid #e5e7eb">
      <h2>Bài viết liên quan</h2>
      {related.map(p => (
        <article class="post-card">
          <h3 style="margin:0;font-size:1.1rem"><a href={`/posts/${p.slug}/`}>{p.data.title}</a></h3>
          {p.data.description && <p class="post-excerpt">{p.data.description}</p>}
        </article>
      ))}
    </section>
  )}
</BaseLayout>
