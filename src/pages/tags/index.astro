---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../utils/slugify';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagMap = new Map<string, number>();
posts.forEach(p => p.data.tags.forEach((t: string) => tagMap.set(t, (tagMap.get(t) || 0) + 1)));
const tags = Array.from(tagMap.entries()).sort((a, b) => b[1] - a[1]);

const breadcrumbs = [
  { name: 'Trang chủ', href: '/' },
  { name: 'Chủ đề', href: '/tags/' }
];
---
<BaseLayout
  title="Tất cả chủ đề — Tin Tức Hub"
  description={`Khám phá ${tags.length} chủ đề bài viết`}
  breadcrumbs={breadcrumbs}
>
  <h1>Tất cả chủ đề ({tags.length})</h1>
  <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin:1.5rem 0">
    {tags.map(([tag, count]) => (
      <a class="tag-badge" href={`/tags/${slugify(tag)}/`} style="font-size:0.95rem;padding:6px 14px">
        {tag} <span style="opacity:0.7">({count})</span>
      </a>
    ))}
  </div>
</BaseLayout>
